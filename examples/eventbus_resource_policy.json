{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowTargetAccountToPutEvents",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::ACCOUNT_B_ID:root"
      },
      "Action": "events:PutEvents",
      "Resource": "arn:aws:events:us-east-1:SOURCE_ACCOUNT_ID:event-bus/YOUR_BUS_OR_DEFAULT_BUS"
    }
  ]
}